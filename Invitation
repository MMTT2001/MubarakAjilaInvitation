<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wedding Invitation</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400&display=swap" rel="stylesheet">

<style>
:root {
  --gold: #d4af37;
  --light: #fdfaf6;
}

body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: var(--light);
  color: #333;
  text-align: center;
  overflow-x: hidden;
}

/* INTRO */
#intro {
  position: fixed;
  width: 100%;
  height: 100vh;
  background: black;
  color: var(--gold);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  z-index: 999;
}

#intro h1 {
  opacity: 0;
  animation: fadeIn 2s forwards;
}

#intro p {
  opacity: 0;
  animation: fadeIn 2s 1s forwards;
}

/* MAIN */
#main {
  opacity: 0;
}

/* HERO */
.hero {
  height: 100vh;
  background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)),
              url('https://images.unsplash.com/photo-1519741497674-611481863552');
  background-size: cover;
  background-position: center;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: 50px;
  animation: fadeIn 2s forwards;
}

.hero p {
  font-size: 20px;
}

/* SECTION */
.section {
  padding: 60px 20px;
}

.card {
  background: white;
  border-radius: 20px;
  padding: 30px;
  max-width: 500px;
  margin: auto;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  animation: slideUp 1.5s ease;
}

h2 {
  color: var(--gold);
}

/* COUNTDOWN */
#countdown {
  font-size: 24px;
  margin-top: 20px;
  color: var(--gold);
}

/* BUTTON */
.btn {
  background: var(--gold);
  color: white;
  padding: 12px 25px;
  border-radius: 30px;
  text-decoration: none;
  display: inline-block;
  margin-top: 20px;
}

/* ANIMATIONS */
@keyframes fadeIn {
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(50px); opacity: 0;}
  to { transform: translateY(0); opacity: 1;}
}
</style>
</head>

<body>

<!-- INTRO -->
<div id="intro">
  <h1>Bismillahir Rahmanir Raheem</h1>
  <p>With the blessings of Allah</p>
</div>

<!-- MAIN -->
<div id="main">

<!-- HERO -->
<div class="hero">
  <h1>You're Invited</h1>
  <p>Join us for our special day</p>
</div>

<!-- INVITATION -->
<div class="section">
  <div class="card">
    <p>With hearts full of gratitude to Allah,</p>
    <p>we invite you to our wedding celebration.</p>

    <h2>YOUR NAME</h2>
    <p>&</p>
    <h2>WIFE NAME</h2>

    <p><strong>Date:</strong> May 31</p>

    <p><strong>Venue:</strong><br>
    Crown Plaza Convention Center,<br>
    Kolathur, Malappuram, Kerala, India</p>

    <div id="countdown"></div>

    <a class="btn" href="https://wa.me/" target="_blank">Send Wishes</a>
  </div>
</div>

<!-- MAP -->
<div class="section">
  <h2>Location</h2>
  <iframe 
    src="https://www.google.com/maps?q=Malappuram%20Kerala&output=embed"
    width="90%" height="300" style="border:0; border-radius:15px;">
  </iframe>
</div>

</div>

<script>
// INTRO TRANSITION
setTimeout(() => {
  document.getElementById("intro").style.display = "none";
  document.getElementById("main").style.opacity = "1";
}, 3500);

// COUNTDOWN
const weddingDate = new Date("May 31, 2026 00:00:00").getTime();

setInterval(() => {
  const now = new Date().getTime();
  const diff = weddingDate - now;

  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  document.getElementById("countdown").innerHTML = days + " Days Remaining";
}, 1000);
</script>

</body>
</html>
